{
  "Urls": "http://127.0.0.1:5080",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "127.0.0.1;localhost",
  "PrivilegedAgent": {
    "PipeName": "storage-visualizer-agent-sawaa-diskmap",
    "ClientToken": "local-dev-agent-token",
    "TimeoutMilliseconds": 1500,
    "TransportMode": "Auto",
    "LoopbackPort": 5091
  },
  "StorageScan": {
    "MinimumChildBytes": 1048576,
    "LockCheckLimit": 200,
    "LargeDirectFileBytes": 104857600,
    "StaleFolderDays": 180,
    "StaleFileDays": 240,
    "StaleFileMinimumBytes": 5242880,
    "MaxStaleFiles": 36,
    "DuplicateMinimumBytes": 1048576,
    "DuplicateHashBytes": 131072,
    "MaxDuplicateCandidateFiles": 1500,
    "MaxDuplicateGroups": 16,
    "MaxDuplicateFilesPerGroup": 8,
    "InspectionPreviewLineLimit": 18,
    "InspectionZipEntryLimit": 20,
    "InspectionHexByteCount": 64,
    "MaxInspectionPreviewBytes": 131072,
    "SkippedDirectoryNames": [
      ".git",
      "node_modules",
      "__pycache__"
    ],
    "ArchiveFileExtensions": [
      ".zip",
      ".rar",
      ".7z",
      ".tar",
      ".gz",
      ".bz2"
    ],
    "InstallerFileExtensions": [
      ".msi",
      ".exe",
      ".msix",
      ".appx",
      ".pkg"
    ],
    "BlockedPathPrefixes": [
      "C:\\Windows"
    ]
  },
  "ReviewWorkspace": {
    "DataDirectory": "App_Data\\reviews",
    "MaxEntriesPerRoot": 1000,
    "MaxNoteLength": 800
  }
}
