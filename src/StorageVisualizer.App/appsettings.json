{
  "Urls": "http://127.0.0.1:5080",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "127.0.0.1;localhost",
  "PrivilegedAgent": {
    "PipeName": "storage-visualizer-agent-sawaa-diskmap",
    "ClientToken": "local-dev-agent-token",
    "TimeoutMilliseconds": 1500,
    "TransportMode": "Auto",
    "LoopbackPort": 5091
  },
  "StorageScan": {
    "MinimumChildBytes": 1048576,
    "LockCheckLimit": 200,
    "SkippedDirectoryNames": [
      ".git",
      "node_modules",
      "__pycache__"
    ],
    "BlockedPathPrefixes": [
      "C:\\Windows"
    ]
  }
}
